{
  "name": "bux",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run ./scripts/dev-all.ts",
    "ui": "bun run --cwd ./apps/playground dev",
    "mcp": "bun run --cwd ./apps/mcp-server start",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "check": "bun run typecheck && bun run test",
    "check:determinism": "bun run scripts/check-determinism.ts",
    "check:snapshot": "bun run scripts/check-snapshot.ts",
    "check:ci": "bun run check && bun run check:determinism && bun run check:snapshot"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.2"
  }
}
