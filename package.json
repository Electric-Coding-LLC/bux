{
  "name": "bux",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "check": "bun run typecheck && bun run test",
    "check:determinism": "bun run scripts/check-determinism.ts",
    "check:ci": "bun run check && bun run check:determinism"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.2"
  }
}
